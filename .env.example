# Sentinel — Environment Configuration
#
# Copy this file to `.env` in the repo root and adjust values for your
# environment:
#
#   cp .env.example .env
#
# docker-compose.yml reads from `.env` automatically. Variables left at their
# defaults below are safe for local development; production deployments MUST
# override the credentials and the JWT secret.
#
# Never commit a real `.env` file (it's in .gitignore).

# =============================================================================
# PostgreSQL — persistent storage for users, domains, scans, findings
# =============================================================================
POSTGRES_DB=sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_dev_pass

# =============================================================================
# RabbitMQ — scanner job queue + DLQ
# =============================================================================
RABBITMQ_DEFAULT_USER=sentinel
RABBITMQ_DEFAULT_PASS=sentinel_dev_pass

# =============================================================================
# API Gateway (Spring Boot)
# =============================================================================
# JWT signing key — HS256 requires >=32 chars. ROTATE this in production.
JWT_SECRET=sentinel-dev-secret-key-change-in-production-min-32-chars

# =============================================================================
# Frontend (Next.js)
# =============================================================================
# Baked into the client bundle at build time. Change this and rebuild the
# frontend image if the API is reachable at a different URL.
NEXT_PUBLIC_API_URL=http://localhost:8080
